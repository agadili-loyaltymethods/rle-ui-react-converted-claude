# API base URL — must be a relative path so requests go through the Vite proxy
VITE_API_BASE_URL=/api

# Feature flags (match AngularJS rle-ui config defaults)
VITE_OKTA_ENABLED=false
VITE_TOKEN_EXPIRATION_BUFFER=120
VITE_TOKEN_TYPE_FOR_CRUD=access_token
VITE_DECIMAL_PRECISION=2
VITE_DISABLE_MEMBER_UNMERGE=false
VITE_DISABLE_SEARCH_FL_NAME=false
VITE_DISABLE_SEARCH_PHONE=false
VITE_DISABLE_SEARCH_EMAIL=false
VITE_DISABLE_POINTS_DIVIDER=false
VITE_ENABLE_AUTO_EXPIRATION=false
